PORT=5174
APP_PIN=change-me
SESSION_SECRET=replace-this-with-a-long-random-value

# Optional local overrides. The server also reads sibling env files from:
# ../dff-workflow-builder/.env, ../dashboards-poultry/.env, and ../timesheets/server/.env
OPENAI_API_KEY=
OPENAI_DIET_MODEL=gpt-5.5
OPENAI_DIET_REASONING_EFFORT=xhigh
# priority is the OpenAI API service tier for fast processing.
OPENAI_DIET_SERVICE_TIER=priority
OPENAI_WORKFLOW_MODEL=
OPENAI_WORKFLOW_REASONING_EFFORT=
OPENAI_WORKFLOW_SERVICE_TIER=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=

DIET_SPREADSHEET_ID=your-spreadsheet-id
DIET_SHEET_TAB_NAME=test
